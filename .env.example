# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================

# Puerto del servidor HTTP
# Default: 3000
PORT=3000

# Puerto del servidor WebSocket (para mensajes en tiempo real)
# Default: 4001
WS_PORT=4001

# Entorno de ejecución
# development = logs habilitados, watch activo
# production = sin logs detallados
NODE_ENV=development

# Modo watch (auto-reload al cambiar código)
# true = reinicia el servidor automáticamente
# false = modo producción sin watch
WATCH=false

# =============================================================================
# AUTENTICACIÓN (REQUERIDO)
# =============================================================================

# Credenciales para acceso al panel admin
# Formato: usuario:password
# IMPORTANTE: Esta variable es OBLIGATORIA
# Ejemplo: OPENCODE_USER_PASSWORD=admin:SecurePass123
OPENCODE_USER_PASSWORD=

# =============================================================================
# OPENCODE AI
# =============================================================================

# API Key de OpenCode para usar Big Pickle
# Obtenerla en https://opencode.ai
# IMPORTANTE: Esta variable es OBLIGATORIA para usar el agente
# Ejemplo: OPENCODE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENCODE_API_KEY=

# Puerto donde se inicia el servidor de OpenCode
# Default: 4099
OPENCODE_PORT=4099

# URL base de la API de OpenCode (opcional)
# Default: https://opencode.ai/zen/v1
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# =============================================================================
# PROMPT DEL SISTEMA
# =============================================================================

# Prompt base que se concatena con el de base de datos
# Usa ${version} para insertar la versión actual del sistema
# Este prompt se envía con cada mensaje al agente
SYSTEM_PROMPT=Eres parte de un sistema de inteligencia artificial que se puede consultar por medio de WhatsApp. Contestarás en el idioma en que te hable el usuario. La versión actual del sistema es ${version}. Serás amable, nunca escribirás palabras antisonantes aunque lo pida el usuario, disculpándote por la negación indicando que tu protocolo no te lo permite. Ajustarás tu respuesta de acuerdo a lo siguiente:

# =============================================================================
# OPCIONALES
# =============================================================================

# Máximo de caracteres para contexto
# Default: 80000
# MAX_CONTEXT_CHARS=80000

# Token Secret para JWT (opcional)
# Si no se define, los tokens se manejan en memoria
# En producción usar un secret seguro
# TOKEN_SECRET=tu-secret-aqui

# Horas de expiry del token de sesión
# Default: 24
# TOKEN_EXPIRY_HOURS=24

# Ruta al ejecutable de Chrome/Chromium (opcional)
# Si puppeteer no encuentra Chrome automáticamente, especifica la ruta aquí
# Ejemplo en Linux: /usr/bin/chromium
# CHROME_PATH=/usr/bin/chromium